# =============================================================================
# Gitignore para Nihil Novi
# =============================================================================

# ---------------------------------------------------------------------------
# Credenciales y archivos sensibles
# ---------------------------------------------------------------------------
sftp_credentials.json
.env
.env.*
*.key
*.pem

# ---------------------------------------------------------------------------
# Archivos binarios grandes: biblioteca de PDFs académicos
# ---------------------------------------------------------------------------
data/pdfs/

# ---------------------------------------------------------------------------
# Artefactos de build / despliegue
# ---------------------------------------------------------------------------
*.zip
*.tar.gz
*.tar

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# ---------------------------------------------------------------------------
# Node (por si se usa en el futuro)
# ---------------------------------------------------------------------------
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ---------------------------------------------------------------------------
# Sistema operativo y editores
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
*.bak
.vscode/
.idea/

# ---------------------------------------------------------------------------
# Planes locales de agentes
# ---------------------------------------------------------------------------
.kimi/
